@inherits LayoutComponentBase

<div class="app-layout">
    <!-- Global Slim Top Navbar -->
    <header class="global-navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <span class="brand-accent">SLIC</span> Apps
            </div>
            <nav class="nav-links">
                <NavLink href="/" Match="NavLinkMatch.All" class="nav-link">Home</NavLink>
                <NavLink href="/location" class="nav-link">Flood Risk</NavLink>
                <NavLink href="/history" class="nav-link">History</NavLink>
                <NavLink href="/landslide-location" class="nav-link">Landslide Risk</NavLink>
                <NavLink href="/landslide" class="nav-link">History</NavLink>
                <NavLink href="/find-agent" class="nav-link">Find Agent</NavLink>
                <NavLink href="/awareness" class="nav-link">Awareness</NavLink>
            </nav>
        </div>
    </header>

    <main class="content page-enter">
        @Body
    </main>
</div>

<style>
    .app-layout {
        min-height: 100vh;
        background-color: var(--bg-primary, #0f172a);
        color: var(--text-primary, #ffffff);
        display: flex;
        flex-direction: column;
    }
    
    .global-navbar {
        position: fixed;
        top: 0;
        z-index: 50;
        width: 100%;
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    }

    .nav-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1400px;
        margin: 0 auto;
        padding: 0.75rem 2rem;
    }

    .nav-brand {
        font-weight: 700;
        font-size: 1.25rem;
        color: white;
        letter-spacing: 1px;
    }

    .brand-accent {
        color: #2dd4bf;
    }

    .nav-links {
        display: flex;
        gap: 0.5rem;
        align-items: flex-end; /* Align tabs to bottom */
        height: 100%;
        margin-bottom: -0.75rem; /* Pull down to touch bottom border */
    }

    .nav-link {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        padding: 0.75rem 1rem;
        border-radius: 6px 6px 0 0;
        transition: all 0.2s;
        border-bottom: 2px solid transparent;
    }

    .nav-link:hover {
        color: #e2e8f0;
        background: rgba(255, 255, 255, 0.05);
    }

    .nav-link.active {
        color: #2dd4bf;
        background: rgba(45, 212, 191, 0.1);
        border-bottom: 2px solid #2dd4bf;
        text-shadow: 0 0 10px rgba(45, 212, 191, 0.3);
    }

    .content {
        flex: 1;
        width: 100%;
        overflow-x: hidden;
        padding-top: 64px; /* Account for fixed navbar height */
    }
</style>

